root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 180

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{json,jsonc,yml,yaml,toml}]
indent_size = 2
tab_width = 2

[*.{xml,csproj,props,targets,resx,config}]
indent_size = 2
tab_width = 2

[*.{sln,slnx}]
end_of_line = crlf
indent_style = space
indent_size = 4
insert_final_newline = false

[*.{bat,cmd}]
end_of_line = crlf

[*.{sh,bash,zsh}]
indent_size = 2
tab_width = 2

[*.cs]
indent_size = 4
tab_width = 4

[*.{c,h,cpp,hpp,cc,cxx,hxx,m,mm}]
indent_size = 4
tab_width = 4

# CMake
[*.{cmake}]
indent_size = 2
tab_width = 2

[CMakeLists.txt]
indent_size = 2
tab_width = 2

[*.{g.cs,generated.cs}]
generated_code = true
